# Environment Setup for CommunityPulse Backend

# ============================================================
# DEPLOYMENT ENVIRONMENT
# ============================================================
ENVIRONMENT=development
DEBUG=false

# ============================================================
# SERVER CONFIGURATION (Render will override PORT automatically)
# ============================================================
PORT=8000
HOST=0.0.0.0

# ============================================================
# FIREBASE CONFIGURATION
# ============================================================
# For Render: Set FIREBASE_SERVICE_ACCOUNT_PATH to /etc/secrets/firebase-admin.json
# and upload firebase-admin.json as a secret file in Render dashboard
FIREBASE_SERVICE_ACCOUNT_PATH=/etc/secrets/firebase-admin.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# ============================================================
# AI CONFIGURATION
# ============================================================
# Google Generative AI (Gemini 2.0 Flash)
GEMINI_API_KEY=your-gemini-api-key-here
AI_PROVIDER=gemini
# Ollama configuration (optional, for fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ============================================================
# EXTERNAL SERVICES
# ============================================================
# Telegram Bot Integration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Vapi Voice Integration
VAPI_API_KEY=your-vapi-api-key-here

# Emergency Volunteer Alert
VOLUNTEER_ALERT_PHONE=+91XXXXXXXXXX

# ============================================================
# CORS CONFIGURATION
# ============================================================
# For Render: Set to your Vercel frontend URL(s)
# Multiple URLs separated by commas
CORS_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# ============================================================
# NOTES FOR RENDER DEPLOYMENT
# ============================================================
# 1. FIREBASE_SERVICE_ACCOUNT_PATH should be: /etc/secrets/firebase-admin.json
# 2. Upload firebase-admin.json as a secret file in Render dashboard
# 3. CORS_ORIGINS must include your Vercel frontend URL
# 4. PORT is automatically set by Render (no need to change)
# 5. DEBUG should be "false" in production
# 6. ENVIRONMENT should be "production" in production
