# CommunityPulse Intelligence Engine Configuration Template
# Rename this file to .env and fill in the required credentials.

# Environment configuration
ENVIRONMENT=development
PORT=8000

# Gemini API Keys (auto-rotating key pool manager)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_1_HERE
GEMINI_API_KEY_2=YOUR_GEMINI_API_KEY_2_HERE
GEMINI_API_KEY_3=YOUR_GEMINI_API_KEY_3_HERE

# Firebase Realtime Database
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com/
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-admin.json

# Tactical Commissioning Codes for Volunteer Verification (Comma-separated)
VOLUNTEER_CODES=PULSE_ADMIN_1,PULSE_VOLUNTEER_2,PULSE_RESCUE_3,PULSE_CORE_4

# WhatsApp API configuration
WHATSAPP_ACCESS_TOKEN=YOUR_WHATSAPP_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_VERIFY_TOKEN=YOUR_VERIFY_TOKEN

# Telegram Bot integration
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Sentry error monitoring
SENTRY_DSN=YOUR_SENTRY_DSN
