# CommunityPulse Frontend Configuration Template
# Rename this file to .env.local and fill in the required credentials.

# Firebase Web configuration
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-firebase-measurement-id
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com/

# Volunteer Access Codes (comma-separated, matches backend config)
NEXT_PUBLIC_VOLUNTEER_CODES=PULSE_ADMIN_1,PULSE_VOLUNTEER_2,PULSE_RESCUE_3,PULSE_CORE_4

# Backend API URL (for local dev, use http://localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Vapi Integration (WebRTC Voice Agent)
NEXT_PUBLIC_VAPI_PUBLIC_KEY=YOUR_VAPI_PUBLIC_KEY
NEXT_PUBLIC_VAPI_ASSISTANT_ID=YOUR_VAPI_ASSISTANT_ID
